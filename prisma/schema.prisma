generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plano {
  BASICO
  MEDIO
  PRO
  TRIAL
}

enum BrechoStatus {
  ATIVO
  TRIAL
  SUSPENSO
}

enum UserRole {
  DONO
  OPERADOR
}

enum StatusPeca {
  DISPONIVEL
  RESERVADO
  VENDIDO
  ENTREGUE
  INDISPONIVEL
}

enum Categoria {
  ROUPA_FEMININA
  ROUPA_MASCULINA
  CALCADO
  ACESSORIO
}

enum Condicao {
  OTIMO
  BOM
  REGULAR
}

enum AcervoTipo {
  PROPRIO
  CONSIGNACAO
}

enum EmailJobStatus {
  PENDENTE
  PROCESSANDO
  ENVIADO
  ERRO
}

enum AIDraftHelpfulness {
  SIM
  PARCIAL
  NAO
}

/// Estado do fluxo de importação multipeças (inbox), separado de StatusPeca.
enum ImportacaoLoteStatus {
  RECEBENDO_FOTOS
  AGRUPANDO
  REVISAR_GRUPOS
  CLASSIFICANDO
  REVISAR_DADOS
  CONCLUIDO
  ERRO
  ABANDONADO
}

enum ImportacaoFotoUploadStatus {
  PENDENTE
  ENVIADA
  ERRO
}

enum ImportacaoGrupoStatus {
  PROPOSTO
  CONFIRMADO
}

enum ImportacaoRascunhoStatus {
  RASCUNHO
  PUBLICADO
  ERRO_CLASSIFICACAO
}

model Brecho {
  id            String       @id @default(cuid())
  nome          String
  slug          String?      @unique
  telefone      String       @unique
  email         String?
  avatarUrl     String?
  plano         Plano
  status        BrechoStatus @default(TRIAL)
  trialExpiraEm DateTime?
  criadoEm      DateTime     @default(now())
  atualizadoEm  DateTime     @updatedAt

  pecas               Peca[]
  clientes            Cliente[]
  emailJobs           EmailJob[]
  aiDraftAnalyses     AIDraftAnalysis[]
  aiDraftFeedbacks    AIDraftFeedback[]
  importacaoLotes     ImportacaoLote[]
  memberships         BrechoMembership[]
  analyticsDias       AnalyticsBrechoDia[]
  analyticsCategorias AnalyticsCategoriaDia[]
}

model User {
  id           String   @id @default(cuid())
  telefone     String   @unique
  nome         String?
  email        String?
  passwordHash String?
  isFounder    Boolean  @default(false)
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  memberships BrechoMembership[]
  sessions    AuthSession[]
}

model BrechoMembership {
  id       String   @id @default(cuid())
  userId   String
  brechoId String
  role     UserRole @default(DONO)
  ativo    Boolean  @default(true)
  criadoEm DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  brecho Brecho @relation(fields: [brechoId], references: [id], onDelete: Cascade)

  @@unique([userId, brechoId])
  @@index([brechoId, role])
  @@index([userId, ativo])
}

model AuthSession {
  id               String    @id @default(cuid())
  userId           String
  refreshTokenHash String?   @unique
  ultimoBrechoId   String?
  expiraEm         DateTime
  criadoEm         DateTime  @default(now())
  revogadoEm       DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiraEm])
}

model Peca {
  id             String     @id @default(cuid())
  brechoId       String
  nome           String
  categoria      Categoria
  subcategoria   String
  cor            String
  estampa        Boolean    @default(false)
  condicao       Condicao
  tamanho        String
  marca          String?
  precoVenda     Decimal?   @db.Decimal(10, 2)
  acervoTipo     AcervoTipo @default(PROPRIO)
  acervoNome     String?
  consignanteId  String?
  status         StatusPeca @default(DISPONIVEL)
  fotoCapaId     String?    @unique
  fotoCapaManual Boolean    @default(false)
  criadoEm       DateTime   @default(now())
  atualizadoEm   DateTime   @updatedAt

  brecho              Brecho                @relation(fields: [brechoId], references: [id])
  fotos               PecaFoto[]
  fotoCapa            PecaFoto?             @relation("PecaFotoCapa", fields: [fotoCapaId], references: [id], onDelete: SetNull)
  fotoLotes           PecaFotoLote[]
  historicoStatus     PecaStatusHistorico[]
  venda               Venda?
  filaInteressados    FilaInteressado[]
  aiDraftFeedbacks    AIDraftFeedback[]
  importacaoRascunhos ImportacaoRascunho[]

  @@index([brechoId, status, criadoEm])
  @@index([brechoId, categoria, subcategoria])
  @@index([brechoId, acervoTipo, acervoNome])
}

/// Contexto opcional (texto e/ou voz) compartilhado por um batch de fotos no mesmo envio.
model PecaFotoLote {
  id               String   @id @default(cuid())
  pecaId           String
  textoNota        String?  @db.Text
  audioUrl         String?
  transcricaoAudio String?  @db.Text
  criadoEm         DateTime @default(now())

  peca  Peca       @relation(fields: [pecaId], references: [id], onDelete: Cascade)
  fotos PecaFoto[]

  @@index([pecaId, criadoEm])
}

model PecaFoto {
  id                    String   @id @default(cuid())
  pecaId                String
  loteId                String?
  url                   String
  thumbnailUrl          String?
  thumbnailTamanhoBytes Int?
  largura               Int?
  altura                Int?
  ordem          Int
  aiAmbiente     String?
  aiQualidade    String?
  aiConfianca    Float?
  aiPredicaoJson Json?
  criadoEm       DateTime @default(now())

  peca       Peca          @relation(fields: [pecaId], references: [id], onDelete: Cascade)
  capaDePeca Peca?         @relation("PecaFotoCapa")
  lote       PecaFotoLote? @relation(fields: [loteId], references: [id], onDelete: SetNull)
  aiAnalyses AIAnalysis[]

  @@unique([pecaId, ordem])
}

model PecaStatusHistorico {
  id        String     @id @default(cuid())
  pecaId    String
  clienteId String?
  status    StatusPeca
  criadoEm  DateTime   @default(now())

  peca    Peca     @relation(fields: [pecaId], references: [id], onDelete: Cascade)
  cliente Cliente? @relation(fields: [clienteId], references: [id])

  @@index([pecaId, criadoEm])
}

model Cliente {
  id        String   @id @default(cuid())
  brechoId  String
  nome      String
  whatsapp  String?
  instagram String?
  criadoEm  DateTime @default(now())

  brecho          Brecho                @relation(fields: [brechoId], references: [id])
  vendas          Venda[]
  filas           FilaInteressado[]
  historicoStatus PecaStatusHistorico[]

  @@index([brechoId, nome])
}

model Venda {
  id          String   @id @default(cuid())
  pecaId      String   @unique
  clienteId   String
  precoVenda  Decimal  @db.Decimal(10, 2)
  freteTexto  String?
  freteValor  Decimal? @db.Decimal(10, 2)
  /// Total da transacao: preco da peca + frete (frete somado).
  ganhosTotal Decimal  @db.Decimal(10, 2)
  criadoEm    DateTime @default(now())

  peca    Peca     @relation(fields: [pecaId], references: [id])
  cliente Cliente  @relation(fields: [clienteId], references: [id])
  entrega Entrega?
}

model Entrega {
  id             String   @id @default(cuid())
  vendaId        String   @unique
  codigoRastreio String?
  entregueEm     DateTime

  venda Venda @relation(fields: [vendaId], references: [id], onDelete: Cascade)
}

model FilaInteressado {
  id        String   @id @default(cuid())
  pecaId    String
  clienteId String
  posicao   Int
  criadoEm  DateTime @default(now())

  peca    Peca    @relation(fields: [pecaId], references: [id], onDelete: Cascade)
  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@unique([pecaId, clienteId])
  @@unique([pecaId, posicao])
  @@index([pecaId, posicao])
}

model AIAnalysis {
  id               String   @id @default(cuid())
  pecaFotoId       String
  nomeSugerido     String?
  categoria        String?
  subcategoria     String?
  corPrincipal     String?
  estampado        Boolean  @default(false)
  descricaoEstampa String?
  condicao         String?
  confianca        Float
  ambienteFoto     String?
  qualidadeFoto    String?
  multiplasPecas   Boolean  @default(false)
  observacoes      String?
  textoContexto    String?
  transcricaoAudio String?
  modeloUsado      String
  tokensConsumidos Int
  criadoEm         DateTime @default(now())

  pecaFoto PecaFoto @relation(fields: [pecaFotoId], references: [id], onDelete: Cascade)
}

model AIDraftAnalysis {
  id                   String   @id @default(cuid())
  brechoId             String
  /// Quando a análise veio de importação multipeças (opcional).
  importacaoLoteId     String?
  importacaoGrupoId    String?
  textoContexto        String?  @db.Text
  imagensJson          Json
  sugestoesJson        Json
  metaJson             Json
  warningsJson         Json
  stage1Json           Json?
  stage2Json           Json?
  fieldConfidenceJson  Json?
  fallbacksAppliedJson Json?
  modeloUsado          String
  tokensConsumidos     Int
  stage1Tokens         Int?
  stage2Tokens         Int?
  stage1LatencyMs      Int?
  stage2LatencyMs      Int?
  criadoEm             DateTime @default(now())

  brecho             Brecho              @relation(fields: [brechoId], references: [id], onDelete: Cascade)
  importacaoLote     ImportacaoLote?     @relation(fields: [importacaoLoteId], references: [id], onDelete: SetNull)
  importacaoGrupo    ImportacaoGrupo?    @relation(fields: [importacaoGrupoId], references: [id], onDelete: SetNull)
  importacaoRascunho ImportacaoRascunho?
  feedbacks          AIDraftFeedback[]

  @@index([brechoId, criadoEm])
  @@index([importacaoLoteId])
  @@index([importacaoGrupoId])
}

model ImportacaoLote {
  id           String               @id @default(cuid())
  brechoId     String
  status       ImportacaoLoteStatus @default(RECEBENDO_FOTOS)
  totalFotos   Int                  @default(0)
  totalGrupos  Int                  @default(0)
  criadoEm     DateTime             @default(now())
  atualizadoEm DateTime             @updatedAt

  brecho          Brecho            @relation(fields: [brechoId], references: [id], onDelete: Cascade)
  fotos           ImportacaoFoto[]
  grupos          ImportacaoGrupo[]
  aiDraftAnalyses AIDraftAnalysis[]

  @@index([brechoId, status, criadoEm])
}

model ImportacaoFoto {
  id                    String                     @id @default(cuid())
  loteId                String
  ordemOriginal         Int
  url                   String
  thumbnailUrl          String?
  mime                  String
  tamanhoBytes          Int?
  thumbnailTamanhoBytes Int?
  largura               Int?
  altura                Int?
  nomeArquivo           String?
  source                String?
  statusUpload          ImportacaoFotoUploadStatus @default(PENDENTE)
  ignorada              Boolean                    @default(false)
  criadoEm              DateTime                   @default(now())

  lote       ImportacaoLote        @relation(fields: [loteId], references: [id], onDelete: Cascade)
  grupoLinks ImportacaoGrupoFoto[]

  @@unique([loteId, ordemOriginal])
  @@index([loteId, ordemOriginal])
}

model ImportacaoGrupo {
  id                   String                @id @default(cuid())
  loteId               String
  ordem                Int
  status               ImportacaoGrupoStatus @default(PROPOSTO)
  confiancaAgrupamento Float?
  motivoRevisao        String?               @db.Text
  ordemInicio          Int
  ordemFim             Int
  temFotosNaoContiguas Boolean               @default(false)
  criadoEm             DateTime              @default(now())

  lote            ImportacaoLote        @relation(fields: [loteId], references: [id], onDelete: Cascade)
  fotoLinks       ImportacaoGrupoFoto[]
  rascunho        ImportacaoRascunho?
  aiDraftAnalyses AIDraftAnalysis[]

  @@index([loteId, ordem])
}

model ImportacaoGrupoFoto {
  id           String @id @default(cuid())
  grupoId      String
  fotoId       String
  ordemNoGrupo Int

  grupo ImportacaoGrupo @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  foto  ImportacaoFoto  @relation(fields: [fotoId], references: [id], onDelete: Cascade)

  @@unique([grupoId, fotoId])
  @@unique([grupoId, ordemNoGrupo])
  @@index([fotoId])
}

model ImportacaoRascunho {
  id              String                   @id @default(cuid())
  grupoId         String                   @unique
  draftAnalysisId String?                  @unique
  formValuesJson  Json?
  status          ImportacaoRascunhoStatus @default(RASCUNHO)
  pecaId          String?                  @unique
  criadoEm        DateTime                 @default(now())
  atualizadoEm    DateTime                 @updatedAt

  grupo    ImportacaoGrupo  @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  analysis AIDraftAnalysis? @relation(fields: [draftAnalysisId], references: [id], onDelete: SetNull)
  peca     Peca?            @relation(fields: [pecaId], references: [id], onDelete: SetNull)
}

model AIDraftFeedback {
  id              String             @id @default(cuid())
  brechoId        String
  analysisId      String
  itemId          String?
  helpfulness     AIDraftHelpfulness
  finalValuesJson Json
  changedFields   String[]
  reasonCodes     String[]
  criadoEm        DateTime           @default(now())

  brecho   Brecho          @relation(fields: [brechoId], references: [id], onDelete: Cascade)
  analysis AIDraftAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  item     Peca?           @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([brechoId, criadoEm])
  @@index([analysisId])
  @@index([itemId])
}

model EmailJob {
  id           String         @id @default(cuid())
  brechoId     String
  tipo         String
  status       EmailJobStatus @default(PENDENTE)
  tentativas   Int            @default(0)
  criadoEm     DateTime       @default(now())
  processadoEm DateTime?

  brecho Brecho @relation(fields: [brechoId], references: [id])
}

model AnalyticsBrechoDia {
  id                  String   @id @default(cuid())
  brechoId            String
  data                DateTime @db.Date
  pecasCadastradas    Int      @default(0)
  pecasVendidas       Int      @default(0)
  faturamentoBruto    Decimal  @default(0) @db.Decimal(12, 2)
  estoqueDisponivel   Int      @default(0)
  estoqueReservado    Int      @default(0)
  estoqueIndisponivel Int      @default(0)
  pecasParadas30d     Int      @default(0)
  criadoEm            DateTime @default(now())
  atualizadoEm        DateTime @updatedAt

  brecho Brecho @relation(fields: [brechoId], references: [id], onDelete: Cascade)

  @@unique([brechoId, data])
  @@index([data])
}

model AnalyticsCategoriaDia {
  id               String    @id @default(cuid())
  brechoId         String
  data             DateTime  @db.Date
  categoria        Categoria
  subcategoria     String?
  pecasCadastradas Int       @default(0)
  pecasVendidas    Int       @default(0)
  faturamentoBruto Decimal   @default(0) @db.Decimal(12, 2)
  criadoEm         DateTime  @default(now())
  atualizadoEm     DateTime  @updatedAt

  brecho Brecho @relation(fields: [brechoId], references: [id], onDelete: Cascade)

  @@unique([brechoId, data, categoria, subcategoria])
  @@index([data, categoria])
}
