DATABASE_URL="postgresql://postgres:postgres@localhost:5432/anna_dev?schema=public"
API_HOST="0.0.0.0"
# Local: use API_PORT. Em PaaS (Railway, etc.) defina só PORT ou deixe o host injetar PORT.
API_PORT="3333"
# PORT="8080"
VITE_API_URL="http://localhost:3333"

# AI
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"
# Opcional: modelo com visão para `POST .../fotos/:fotoId/analisar` (default gpt-4o-mini)
OPENAI_VISION_MODEL=""

# Auth / OTP
JWT_SECRET=""
# Bootstrap local/interno para criar usuário fundador via `npm run seed:founder -w @anna/api`
FOUNDER_BOOTSTRAP_PHONE=""
FOUNDER_BOOTSTRAP_PASSWORD=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM=""

# Storage (S3-compatible: MinIO, AWS, etc. — necessário para upload presigned no fluxo de fotos)
STORAGE_ENDPOINT=""
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""
STORAGE_BUCKET=""
STORAGE_REGION=""
STORAGE_PUBLIC_BASE_URL=""

# Aliases AWS/Railway (opcional): se STORAGE_* estiver vazio, a API usa estes nomes.
# AWS_ENDPOINT_URL=https://s3.sa-east-1.amazonaws.com
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=sa-east-1
# AWS_S3_BUCKET_NAME=
# AWS_S3_PUBLIC_BASE_URL=https://seu-cdn-ou-bucket-publico/   # opcional

# Email
RESEND_API_KEY=""

# Worker stub de fila de e-mail (opcional; ver `npm run worker:email`)
EMAIL_JOB_POLL_MS="8000"
